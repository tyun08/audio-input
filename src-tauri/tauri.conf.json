{
  "productName": "Audio Input",
  "version": "0.4.10",
  "identifier": "com.audioinput.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Audio Input",
        "width": 200,
        "height": 44,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist",
      "signingIdentity": "Developer ID Application: Jingtao Yun (V8RQ99X6H4)",
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzRDUzNkQyOTUzMUY4RUUKUldUdStER1YwamJWTTRCM0tzeHhyMmZ1NlowdDhIMUkweHV3aGNodmMxRjdlQmFDMGY2bURvUlYK",
      "endpoints": [
        "https://github.com/tyun08/audio-input/releases/latest/download/latest.json"
      ]
    }
  }
}
